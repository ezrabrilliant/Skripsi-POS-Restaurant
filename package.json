{
  "name": "pos-restaurant",
  "version": "1.0.0",
  "description": "Web-based POS System for Restaurant",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && php artisan serve --port=8000",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "install:all": "cd frontend && npm install",
    "db:migrate": "cd backend && php artisan migrate",
    "db:seed": "cd backend && php artisan db:seed",
    "db:fresh": "cd backend && php artisan migrate:fresh --seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
