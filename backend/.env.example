# Koneksi MySQL - ganti user/password/host sesuai instalasi lokal
# Format: mysql://USER:PASSWORD@HOST:PORT/NAMA_DATABASE
# Contoh XAMPP/Laragon (password root kosong): mysql://root:@localhost:3306/pos_restaurant
DATABASE_URL="mysql://root:password@localhost:3306/pos_restaurant"

# Rahasia untuk menandatangani JWT - ganti dengan string acak panjang di produksi
JWT_SECRET="ganti-dengan-string-rahasia-yang-panjang-dan-acak"

# Masa berlaku token login
JWT_EXPIRES_IN="12h"

# Port server API
PORT=8000

# Lingkungan: development | production
NODE_ENV=development

# Origin frontend yang diizinkan akses API (CORS)
CORS_ORIGIN="http://localhost:3000"

# Jumlah meja di restoran
TABLE_COUNT=20
