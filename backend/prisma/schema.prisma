// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// USERS TABLE
// =============================================
model User {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  role      UserRole
  pinCode   String   @map("pin_code") @db.VarChar(6)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  transactions Transaction[]
  settlements  Settlement[]

  @@index([pinCode])
  @@map("users")
}

enum UserRole {
  owner
  cashier
}

// =============================================
// MENUS TABLE
// =============================================
model Menu {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(150)
  price       Decimal  @db.Decimal(12, 2)
  category    String   @db.VarChar(50)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  dailyStocks      DailyMenuStock[]
  transactionItems TransactionItem[]

  @@index([category])
  @@index([isActive])
  @@map("menus")
}

// =============================================
// DAILY MENU STOCKS TABLE
// =============================================
model DailyMenuStock {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  menuId    String   @map("menu_id")
  stockStart Int     @default(0) @map("stock_start")
  stockSold  Int     @default(0) @map("stock_sold")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([date, menuId])
  @@index([date])
  @@index([menuId])
  @@map("daily_menu_stocks")
}

// =============================================
// TRANSACTIONS TABLE
// =============================================
model Transaction {
  id             String            @id @default(uuid())
  tableNumber    String            @map("table_number") @db.VarChar(20)
  status         TransactionStatus @default(open)
  paymentMethod  String?           @map("payment_method") @db.VarChar(50)
  subtotal       Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount Decimal           @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal           @default(0) @map("total_amount") @db.Decimal(12, 2)
  amountPaid     Decimal           @default(0) @map("amount_paid") @db.Decimal(12, 2)
  changeAmount   Decimal           @default(0) @map("change_amount") @db.Decimal(12, 2)
  notes          String?           @db.Text
  cashierId      String?           @map("cashier_id")
  paidAt         DateTime?         @map("paid_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  // Relations
  cashier User?             @relation(fields: [cashierId], references: [id])
  items   TransactionItem[]

  @@index([status])
  @@index([tableNumber])
  @@index([createdAt])
  @@index([paidAt])
  @@map("transactions")
}

enum TransactionStatus {
  open
  paid
  void
}

// =============================================
// TRANSACTION ITEMS TABLE
// =============================================
model TransactionItem {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  menuId        String   @map("menu_id")
  menuName      String   @map("menu_name") @db.VarChar(150)
  quantity      Int
  priceAtTime   Decimal  @map("price_at_time") @db.Decimal(12, 2)
  subtotal      Decimal  @db.Decimal(12, 2)
  notes         String?  @db.Text
  isForceOrder  Boolean  @default(false) @map("is_force_order")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  menu        Menu        @relation(fields: [menuId], references: [id])

  @@index([transactionId])
  @@index([menuId])
  @@map("transaction_items")
}

// =============================================
// SETTLEMENTS TABLE
// =============================================
model Settlement {
  id             String           @id @default(uuid())
  date           DateTime         @unique @db.Date
  cashierId      String           @map("cashier_id")
  systemCash     Decimal          @default(0) @map("system_cash") @db.Decimal(12, 2)
  systemEdc      Decimal          @default(0) @map("system_edc") @db.Decimal(12, 2)
  systemTransfer Decimal          @default(0) @map("system_transfer") @db.Decimal(12, 2)
  systemTotal    Decimal          @default(0) @map("system_total") @db.Decimal(12, 2)
  actualCash     Decimal          @default(0) @map("actual_cash") @db.Decimal(12, 2)
  actualEdc      Decimal          @default(0) @map("actual_edc") @db.Decimal(12, 2)
  actualTransfer Decimal          @default(0) @map("actual_transfer") @db.Decimal(12, 2)
  actualTotal    Decimal          @default(0) @map("actual_total") @db.Decimal(12, 2)
  varianceReason String?          @map("variance_reason") @db.Text
  status         SettlementStatus @default(pending)
  notes          String?          @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  cashier User @relation(fields: [cashierId], references: [id])

  @@index([date])
  @@map("settlements")
}

enum SettlementStatus {
  pending
  submitted
  reviewed
}
