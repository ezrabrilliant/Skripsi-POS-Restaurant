// Skema basis data Sistem POS Restoran Ayam Bakar Banjar Monosuko (REV 2.5).
// Sumber kebenaran alur bisnis: docs/operasional-resto.md REV 2.3 (REV 2.5 bump pending)
// Sumber struktur data: docs/knowledge/ERD.md
// Spec implementasi REV 2.5 split tender: docs/superpowers/specs/2026-05-26-split-tender-combine-design.md
// Spec implementasi REV 2.5 raw materials redesign: docs/superpowers/specs/2026-05-26-stok-raw-purchasing-redesign-design.md
//
// 16 entitas, 22 relasi. Primary key memakai auto-increment integer (INT MySQL),
// kecuali PortionStock yang PK-nya menu_id (1:1 dengan Menu).
//
// REV 2.5 (2026-05-26): tambah TransactionPayment table untuk support multi-method
// per transaction (Split Tender). Drop Transaction.paymentMethod + paymentBank
// (single field obsolete), drop TransactionItem.partyId (split bill multi-party drop).
// Settlement & dashboard byMethod query refactor pakai groupBy TransactionPayment.
//
// REV 2.5 raw materials redesign (2026-05-26): tambah master Unit dengan opname_mode
// enum (exact vs scale_0_5). RawMaterial.unit varchar diganti unitId FK. PurchaseItem
// qty + unit_price jadi nullable + tambah note untuk support scale_0_5 items (purchase
// HANYA log expense, tidak update stock_qty).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

/// 3 role: owner, kasir, waiter. Tidak ada "kitchen" - masak out of scope.
enum UserRole {
  owner
  cashier
  waiter
}

enum TransactionStatus {
  open
  paid
  void
}

/// 2 tipe order saja (REV 2.1: disederhanakan dari 5). Sumber takeaway
/// (walk-in, GoFood, GrabFood, gosend) dibedakan via metode pembayaran.
enum OrderType {
  dineIn   @map("dine_in")
  takeaway
}

/// REV 2.6 RENAME: was `PaymentMethod`, renamed jadi `PaymentMethodLegacy` karena
/// REV 2.6 introduce model `PaymentMethod` (master table). Enum tetap di-keep untuk
/// legacy code di transactions/settlements/dashboard service yang refer ke enum
/// values; akan di-drop FULL di Phase 9 setelah semua call-site migrate ke
/// master-table lookup. Mapped ke MySQL enum type lama via @@map.
///
/// 6 metode pembayaran. EDC dan transfer dipisah per bank via field
/// Transaction.payment_bank nullable.
///
/// cash/edc/qris   -> dine-in & takeaway walk-in
/// gojek/grab      -> takeaway via aggregator merchant app (settlement)
/// transfer        -> dine-in / takeaway / gosend teman owner
enum PaymentMethodLegacy {
  cash
  edc
  qris
  gojek
  grab
  transfer

  @@map("PaymentMethod")
}

enum SettlementStatus {
  submitted
  reviewed
}

/// 2 shift fixed per hari per kasir. Pagi mulai sebelum 10:00, malam mulai 18:00.
enum ShiftType {
  pagi
  malam
}

/// Klasifikasi menu berdasarkan apakah ditrack stok porsi.
/// - portion  = menu sendiri yang punya PortionStock (auto-decrement saat order).
/// - linked   = menu varian yang men-decrement stok porsi menu lain (subOptions.stockTarget).
/// - nonStock = tetap tampil di POS tapi tidak decrement (minuman, nasi, sambal, paket dengan subOptions.stockMap).
enum StockType {
  portion  @map("portion")
  linked   @map("linked")
  nonStock @map("non_stock")
}

/// REV 2.2: RENAME dari StockMovementReason. Audit log perubahan PortionStock.
/// refund_void ditambah untuk antisipasi void transaksi yang sudah submit.
enum PortionMovementReason {
  order            @map("order")
  restockMorning   @map("restock_morning")
  restockEmergency @map("restock_emergency")
  manualAdjust     @map("manual_adjust")
  refundVoid       @map("refund_void")
}

/// REV 2.2: BARU. Audit log perubahan RawMaterial.stock_qty.
/// purchase auto-insert saat PurchaseItem submit; opname saat opname raw materials;
/// manual_adjust untuk koreksi langsung via halaman Raw Materials.
enum RawMaterialMovementReason {
  purchase
  opname
  manualAdjust @map("manual_adjust")
}

/// REV 2.1: BARU (ganti BulkStockKind rigid).
/// Pengelompokan raw material untuk laporan owner. Item is_tracked=false
/// kategori bumbu_dasar di-grouping jadi 1 baris "Bumbu Dasar" di laporan
/// agregat dengan drill-down detail per item.
enum RawMaterialCategory {
  bumbuDasar  @map("bumbu_dasar")
  bahanSegar  @map("bahan_segar")
  bahanPokok  @map("bahan_pokok")
  bahanKering @map("bahan_kering")
  lainnya
}

/// Kategori tagihan operasional bulanan (owner only).
enum BillCategory {
  kebersihan
  listrik
  air
  parkir
  sewa
}

/// REV 2.5 (raw materials redesign): Mode opname per satuan.
/// - exact: stock_qty integer/decimal dalam unit, purchase auto stock_qty += qty
/// - scale_0_5: stock_qty 0..5 (subjective fullness), purchase HANYA log expense
enum OpnameMode {
  exact
  scale_0_5
}

/// REV 2.5 BARU: Master satuan untuk raw materials. Dropdown source di form
/// add/edit raw material. opname_mode menentukan UI + behavior:
/// - exact mode: opname input angka, purchase auto stock_qty += qty
/// - scale_0_5 mode: opname segmented 0..5, purchase HANYA log expense
///
/// Pre-seeded di seed.ts: kg, gram, liter, butir, balok, karung, ikat, batang,
/// pcs (semua exact) + "skala 0-5" (scale_0_5). Owner dapat add unit baru
/// via dropdown modal di form raw material.
model Unit {
  id         Int        @id @default(autoincrement())
  label      String     @unique @db.VarChar(50)
  opnameMode OpnameMode @map("opname_mode")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  rawMaterials RawMaterial[]

  @@map("units")
}

// ============================================================
// ENTITAS UTAMA (16 entitas REV 2.5)
// ============================================================

/// 1. Pengguna sistem: owner, cashier, waiter. Login via (nama, PIN 6 digit).
/// PIN BOLEH DUPLIKAT antar pegawai - identifikasi via nama, PIN cuma password.
/// REV 2.3 catatan: tidak ada layar pilih nama dari daftar. Form 2 field input
/// nama + PIN murni setiap login (no localStorage remember last user).
model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  pin       String   @db.VarChar(6)
  role      UserRole
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  /// REV 2.3 shift-decoupling: rename dari `transactions` jadi `transactionsCreated`
  /// supaya jelas semantik = transaksi yang USER INI submit (audit trail),
  /// bukan transaksi shift kasir.
  transactionsCreated  Transaction[]
  shifts               Shift[]
  settlementsCashier   Settlement[]          @relation("SettlementCashier")
  settlementsReview    Settlement[]          @relation("SettlementReviewer")
  purchases            Purchase[]
  bills                Bill[]
  portionMovements     PortionMovement[]
  rawMaterialMovements RawMaterialMovement[]
  /// REV 2.5: payment slices yang user ini record (audit per slice di split tender).
  recordedPayments     TransactionPayment[]

  @@map("users")
}

/// 2. Katalog menu siap jual (target 60 item: 25 stok porsi + linked + non-stok + 5 paket).
/// stockType=portion  -> link 1:1 ke PortionStock (auto-decrement saat order).
/// stockType=linked   -> share stok porsi menu lain via subOptions.stockTarget.
/// stockType=nonStock -> tampil di POS tapi tidak pengaruh stok.
/// subOptions=non-null -> menu adalah paket dengan pilihan dinamis (Paket A/B/C/D/Keluarga).
model Menu {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(100)
  category   String    @db.VarChar(50)
  price      Decimal   @db.Decimal(10, 2)
  stockType  StockType @default(nonStock) @map("stock_type")
  /// Minimum stok untuk reminder restock. Hanya bermakna jika stockType=portion.
  minStock   Int?      @map("min_stock")
  /// Path relatif foto menu (mis. /menu/ayam-bakar.webp) atau URL absolut.
  imageUrl   String?   @map("image_url") @db.VarChar(255)
  /// Definisi sub-pilihan untuk paket. Struktur JSON dengan options[] + stockMap.
  subOptions Json?     @map("sub_options")
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  portionStock     PortionStock?
  transactionItems TransactionItem[]
  portionMovements PortionMovement[]

  @@map("menus")
}

/// 3. Live count stok porsi per menu (1:1 dengan Menu yang stockType=portion).
/// Tidak per-tanggal - currentQty adalah snapshot saat ini yang terus berubah.
/// Boleh negatif (stok minus dibolehkan; restock via "Barang Masuk" akan menambah).
///
/// REV 2.1 BARU: openingQtyToday + openingQtyDate auto-snapshot saat user pertama
/// login pagi. Dipakai untuk metric "terjual hari ini" di dashboard.
/// Metric = opening_qty_today + sum(restock_today_movements) − current_qty
model PortionStock {
  menuId          Int      @id @map("menu_id")
  currentQty      Int      @map("current_qty")
  /// Duplicate dari Menu.min_stock untuk kemudahan query reminder.
  minStock        Int      @default(0) @map("min_stock")
  /// Snapshot otomatis qty saat user pertama login pagi. Trigger auto-snapshot
  /// di middleware backend saat openingQtyDate < today.
  openingQtyToday Int      @default(0) @map("opening_qty_today")
  openingQtyDate  DateTime @default(dbgenerated("(CURRENT_DATE)")) @map("opening_qty_date") @db.Date
  updatedAt       DateTime @updatedAt @map("updated_at")

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("portion_stocks")
}

/// 4. Log audit semua perubahan PortionStock (REV 2.2: RENAME dari stock_movements).
/// delta bisa negatif (order, opname turun) atau positif (restock, opname naik).
/// Wajib referensi user yang melakukan untuk akuntabilitas.
model PortionMovement {
  id        Int                   @id @default(autoincrement())
  menuId    Int                   @map("menu_id")
  delta     Int
  reason    PortionMovementReason
  /// Catatan opsional. Untuk order: "transactionId=123". Untuk restock_emergency:
  /// "Antar via Gojek 18:30". Untuk manual_adjust: "Opname pagi selisih +1/-2".
  note      String?               @db.VarChar(255)
  userId    Int                   @map("user_id")
  createdAt DateTime              @default(now()) @map("created_at")

  menu Menu @relation(fields: [menuId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([menuId, createdAt])
  @@map("portion_movements")
}

/// 5. Master bahan baku (REV 2.5.1: SIMPLIFIED — drop is_tracked).
/// Semua master raw_materials = always tracked (Beras, Kangkung, Petai, Tahu,
/// Tempe, Telur). Bumbu dasar + ayam mentah + ikan mentah TIDAK ada master,
/// di-catat sebagai free-form line item di PurchaseItem (label text, no FK).
///
/// Field freshness_days opsional untuk perishable: reminder mendekati basi
/// (freshness_days − 3) hari setelah last_buy_date.
///
/// REV 2.5.2 (2026-05-27): tambah `isActive` flag untuk soft-delete proper.
/// Delete behavior bifurcated:
/// - No FK refs (purchase_items + raw_material_movements both 0) → hard delete.
/// - FK refs exist → soft delete (set isActive=false), audit trail preserved.
/// List default filter isActive=true; owner bisa kirim ?includeInactive=true
/// untuk lihat semua dan reactivate via POST /raw-materials/:id/reactivate.
model RawMaterial {
  id            Int                 @id @default(autoincrement())
  name          String              @db.VarChar(100)
  /// REV 2.5: FK ke master Unit. Opname behavior (exact vs scale_0_5) ditentukan
  /// dari unit.opname_mode, bukan disimpan di sini.
  unitId        Int                 @map("unit_id")
  unit          Unit                @relation(fields: [unitId], references: [id])
  category      RawMaterialCategory
  /// REV 2.5.2: soft-delete flag. False = nonaktif (tersembunyi dari list default,
  /// FK refs preserved untuk audit). Default true.
  isActive      Boolean             @default(true) @map("is_active")
  stockQty      Decimal             @default(0) @map("stock_qty") @db.Decimal(10, 2)
  /// Ambang reminder restock.
  minStock      Int?                @map("min_stock")
  /// Harga per unit terakhir, auto-update saat purchase baru.
  unitPrice     Decimal?            @map("unit_price") @db.Decimal(10, 2)
  /// Untuk perishable (mis. 10 untuk kangkung). Reminder muncul (freshness − 3) hari setelah last_buy_date.
  freshnessDays Int?                @map("freshness_days")
  /// Tanggal pembelian terakhir, auto-update saat purchase_items submit.
  lastBuyDate   DateTime?           @map("last_buy_date") @db.Date
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  purchaseItems        PurchaseItem[]
  rawMaterialMovements RawMaterialMovement[]

  @@map("raw_materials")
}

/// 6. Log audit perubahan RawMaterial.stock_qty (REV 2.2: BARU).
/// Auto-insert oleh sistem di 3 trigger:
/// - purchase: tiap PurchaseItem submit dengan raw_material is_tracked=true → delta=+qty
/// - opname  : tiap submit opname raw materials yang ubah stock_qty → delta=selisih
/// - manualAdjust: koreksi manual via halaman Raw Materials (owner/kasir)
model RawMaterialMovement {
  id            Int                       @id @default(autoincrement())
  rawMaterialId Int                       @map("raw_material_id")
  delta         Decimal                   @db.Decimal(10, 2)
  reason        RawMaterialMovementReason
  /// Catatan opsional. Untuk purchase: "Purchase id=X dari Vendor Y".
  /// Untuk opname: "Opname malam: dari 2 ikat jadi 0 ikat".
  note          String?                   @db.VarChar(255)
  userId        Int                       @map("user_id")
  createdAt     DateTime                  @default(now()) @map("created_at")

  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@index([rawMaterialId, createdAt])
  @@map("raw_material_movements")
}

/// 7. Master vendor/toko/pasar tempat belanja (REV 2.1: BARU, opsional di Purchase).
/// Phone dan note opsional karena di pasar kadang kasir lupa nama penjual atau
/// penjualnya perorangan tanpa nomor telepon.
model Vendor {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  /// Jenis vendor: "toko" / "pasar" / "individu"
  type      String   @db.VarChar(50)
  phone     String?  @db.VarChar(20)
  note      String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchases Purchase[]

  @@map("vendors")
}

/// 8. Siklus shift kasir. REV 2.5 multi-cashier sharing: shift = container per
/// (tanggal, tipe). Hanya 1 shift pagi + 1 shift malam AKTIF (closedAt null) per
/// hari - di-enforce di app layer via shifts.service.openShift (cek findFirst
/// closedAt=null sebelum create). Kasir bisa buka, tutup, lalu buka lagi di hari
/// yang sama (mis. typo modal awal, atau pergantian shift balik lagi).
///
/// REV 2.5 catatan: `@@unique([date, cashierId, type])` di-DROP karena terlalu
/// strict - menahan kasir buka shift tipe sama setelah tutup di hari yang sama.
/// App-layer constraint cukup (findFirst aktif), audit/dedup via app logic.
model Shift {
  id          Int       @id @default(autoincrement())
  date        DateTime  @db.Date
  type        ShiftType
  cashierId   Int       @map("cashier_id")
  openingCash Decimal   @map("opening_cash") @db.Decimal(12, 2)
  closedAt    DateTime? @map("closed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  cashier      User          @relation(fields: [cashierId], references: [id])
  transactions Transaction[]
  settlement   Settlement?

  @@index([date, type, closedAt])
  @@map("shifts")
}

/// 9. Header pesanan.
/// - Dine-in: wajib tableNumber. Multi-round per sesi meja.
/// - Takeaway: tableNumber null. Sumber order dibedakan via payment method (lihat TransactionPayment).
/// - taxAmount = PB1 10% dari (subtotal - discountAmount).
/// - total = subtotal - discountAmount + taxAmount.
///
/// REV 2.5 (2026-05-26):
/// - paymentMethod + paymentBank fields DI-DROP. Pindah ke TransactionPayment table
///   (1-N) untuk support Split Tender (1 transaction multi payment method).
/// - sum(payments.amount) == total saat status=paid. Validasi di service layer.
///
/// REV 2.1 catatan yang tetap berlaku:
/// - mergedIntoId: self-ref nullable untuk merge bill. Transaksi sumber yang
///   di-merge punya merged_into_id = parent gabungan.
///
/// REV 2.3 shift-decoupling:
/// - createdById (RENAME dari cashier_id) = user yang submit order
///   (kasir/owner/waiter via fallback). Untuk "kasir pemilik shift" akses
///   via shift.cashier (denormalize ke view sebagai shiftCashierName).
/// - shiftId tetap = ID shift fiskal aktif saat order dibuat (rekap uang masuk).
model Transaction {
  id             Int               @id @default(autoincrement())
  shiftId        Int               @map("shift_id")
  orderType      OrderType         @map("order_type")
  tableNumber    Int?              @map("table_number")
  createdById    Int               @map("created_by_id")
  status         TransactionStatus @default(open)
  /// REV 2.1: self-reference untuk merge bill. Null = transaksi normal/parent.
  /// Non-null = transaksi sumber yang sudah di-merge ke parent (id parent).
  mergedIntoId   Int?              @map("merged_into_id")
  subtotal       Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount Decimal           @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount      Decimal           @default(0) @map("tax_amount") @db.Decimal(12, 2)
  total          Decimal           @default(0) @db.Decimal(12, 2)
  createdAt      DateTime          @default(now()) @map("created_at")
  paidAt         DateTime?         @map("paid_at")
  voidedAt       DateTime?         @map("voided_at")

  shift      Shift                @relation(fields: [shiftId], references: [id])
  createdBy  User                 @relation(fields: [createdById], references: [id])
  items      TransactionItem[]
  payments   TransactionPayment[]
  mergedInto Transaction?         @relation("MergeBill", fields: [mergedIntoId], references: [id])
  mergedFrom Transaction[]        @relation("MergeBill")

  @@map("transactions")
}

/// 10. Detail item dalam transaksi. unitPrice = snapshot saat order.
/// subOptionsSelected (JSON): hasil pilihan SubOptionsModal untuk paket
///   format: { ayamPart: "Paha", cook: "Bakar", minuman: "Teh Tawar" }
/// notes (REV 2.4): catatan per item dari waiter/kasir saat input order
///   - komunikasi customer ke dapur (mis. "kurang manis", "pedas level 2",
///   "Panas" / "Dingin" untuk teh & jeruk yang ambigu suhu).
///
/// REV 2.5: partyId field DI-DROP. Split bill multi-party tidak diadopsi di REV 2.5
/// (konteks Indo: rare, customer pakai Splitwise / transfer pribadi). Untuk
/// scenario serupa, pakai Split Tender (TransactionPayment multi-method).
model TransactionItem {
  id                 Int      @id @default(autoincrement())
  transactionId      Int      @map("transaction_id")
  menuId             Int      @map("menu_id")
  qty                Int
  unitPrice          Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal           Decimal  @db.Decimal(12, 2)
  subOptionsSelected Json?    @map("sub_options_selected")
  notes              String?  @db.VarChar(255)
  createdAt          DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  menu        Menu        @relation(fields: [menuId], references: [id])

  @@map("transaction_items")
}

/// 10b. Slice pembayaran per Transaction (REV 2.5 BARU - support Split Tender).
/// 1 Transaction punya 1+ TransactionPayment records. Sum(amount) == Transaction.total
/// saat status=paid (validasi di service layer addPayment).
///
/// Single tender: 1 record (method+bank+amount=total).
/// Split tender:  N records (cash 100k + qris 65k, dst).
///
/// Bank wajib untuk method=edc atau transfer (validasi Zod superRefine + service).
/// recordedBy = user yang submit slice (audit per slice, bukan user pemilik shift).
model TransactionPayment {
  id            Int      @id @default(autoincrement())
  transactionId Int      @map("transaction_id")
  /// REV 2.6: denormalize dari payment_methods.code (audit-safe).
  /// Validasi runtime di service: harus exist di payment_methods table.
  method        String   @db.VarChar(20)
  bank          String?  @db.VarChar(50)
  amount        Decimal  @db.Decimal(12, 2)
  recordedAt    DateTime @default(now()) @map("recorded_at")
  recordedById  Int      @map("recorded_by_id")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  recordedBy  User        @relation(fields: [recordedById], references: [id])

  @@index([transactionId])
  @@map("transaction_payments")
}

/// 11. Rekap akhir hari (kasir shift malam saja). 1:1 dengan Shift (shift malam).
/// Bukan blind count rumit - simpel 6 totals (sistem) + 6 totals (fisik) + variance di runtime.
/// Modal awal kasir di-track di Shift, ditampilkan di summary tapi tidak ikut variance.
///
/// Breakdown per bank untuk EDC dan transfer dihitung di runtime dari
/// TransactionPayment GROUP BY method, bank (REV 2.5), tidak disimpan duplikat.
model Settlement {
  id             Int              @id @default(autoincrement())
  shiftId        Int              @unique @map("shift_id")
  date           DateTime         @db.Date
  cashierId      Int              @map("cashier_id")
  reviewerId     Int?             @map("reviewer_id")
  systemCash     Decimal          @map("system_cash") @db.Decimal(12, 2)
  systemEdc      Decimal          @map("system_edc") @db.Decimal(12, 2)
  systemQris     Decimal          @map("system_qris") @db.Decimal(12, 2)
  systemGojek    Decimal          @map("system_gojek") @db.Decimal(12, 2)
  systemGrab     Decimal          @map("system_grab") @db.Decimal(12, 2)
  systemTransfer Decimal          @map("system_transfer") @db.Decimal(12, 2)
  actualCash     Decimal          @map("actual_cash") @db.Decimal(12, 2)
  actualEdc      Decimal          @map("actual_edc") @db.Decimal(12, 2)
  actualQris     Decimal          @map("actual_qris") @db.Decimal(12, 2)
  actualGojek    Decimal          @map("actual_gojek") @db.Decimal(12, 2)
  actualGrab     Decimal          @map("actual_grab") @db.Decimal(12, 2)
  actualTransfer Decimal          @map("actual_transfer") @db.Decimal(12, 2)
  status         SettlementStatus @default(submitted)
  submittedAt    DateTime         @default(now()) @map("submitted_at")
  reviewedAt     DateTime?        @map("reviewed_at")

  shift        Shift                   @relation(fields: [shiftId], references: [id])
  cashier      User                    @relation("SettlementCashier", fields: [cashierId], references: [id])
  reviewer     User?                   @relation("SettlementReviewer", fields: [reviewerId], references: [id])
  methodCounts SettlementMethodCount[]

  @@map("settlements")
}

/// 12. Header log belanja kasir di pasar (REV 2.1: normalized, no more JSON items).
/// Vendor opsional karena di pasar kadang lupa nama penjual.
/// Detail per item di tabel PurchaseItem.
model Purchase {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  userId      Int      @map("user_id")
  vendorId    Int?     @map("vendor_id")
  totalAmount Decimal  @map("total_amount") @db.Decimal(12, 2)
  note        String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  user   User           @relation(fields: [userId], references: [id])
  vendor Vendor?        @relation(fields: [vendorId], references: [id])
  items  PurchaseItem[]

  @@index([date])
  @@map("purchases")
}

/// 13. Detail per baris item dalam satu Purchase.
///
/// REV 2.5.1: 2 jenis line item:
///   A. Typed (rawMaterialId set, label null) — FK ke master RawMaterial.
///      Saat submit, sistem auto-update raw_materials.last_buy_date,
///      unit_price (kalau diisi), stock_qty += qty (kalau unit exact mode),
///      plus log raw_material_movements reason=purchase.
///   B. Free-form (rawMaterialId null, label set) — text label bebas untuk
///      bumbu dasar / ayam mentah / ikan mentah / item tanpa master.
///      Hanya log expense (subtotal + note opsional). Tidak update stok,
///      tidak insert raw_material_movements.
///
/// Validation di service layer: exactly one of {rawMaterialId, label} set.
model PurchaseItem {
  id            Int       @id @default(autoincrement())
  purchaseId    Int       @map("purchase_id")
  /// REV 2.5.1: nullable. Null = free-form line item (pakai label).
  rawMaterialId Int?      @map("raw_material_id")
  /// REV 2.5.1 BARU: label text untuk free-form line item (mis. "Bumbu Dasar",
  /// "Ayam Mentah"). Null kalau pakai rawMaterialId (typed).
  label         String?   @db.VarChar(100)
  /// REV 2.5: nullable untuk scale_0_5 items (qty tidak relevan, hanya log expense).
  /// REV 2.5.1: juga null untuk free-form items.
  qty           Decimal?  @db.Decimal(10, 2)
  /// REV 2.5: nullable untuk scale_0_5 items.
  /// REV 2.5.1: juga null untuk free-form items.
  unitPrice     Decimal?  @map("unit_price") @db.Decimal(10, 2)
  subtotal      Decimal   @db.Decimal(12, 2)
  /// REV 2.5 BARU: catatan opsional per item (mis. "beli sekarung Cabai 2kg").
  note          String?   @db.VarChar(255)
  /// Opsional, untuk perishable.
  expiredDate   DateTime? @map("expired_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")

  purchase    Purchase     @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  rawMaterial RawMaterial? @relation(fields: [rawMaterialId], references: [id])

  @@map("purchase_items")
}

/// 14. Tagihan operasional bulanan - owner only (validasi di service layer).
/// REV 2.3: month tetap VARCHAR(7) format "YYYY-MM".
model Bill {
  id        Int          @id @default(autoincrement())
  /// Format YYYY-MM (mis. "2026-05")
  month     String       @db.VarChar(7)
  category  BillCategory
  amount    Decimal      @db.Decimal(12, 2)
  note      String?      @db.VarChar(255)
  userId    Int          @map("user_id")
  createdAt DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([month])
  @@map("bills")
}

/// 15. REV 2.6: Master payment method. Drop enum PaymentMethod (Phase 9).
/// Owner-configurable: bisa add method baru (mis. ShopeePay).
model PaymentMethod {
  id               Int                     @id @default(autoincrement())
  code             String                  @unique @db.VarChar(20)
  label            String                  @db.VarChar(50)
  colorHex         String                  @map("color_hex") @db.VarChar(7)
  iconName         String                  @map("icon_name") @db.VarChar(30)
  requiresBank     Boolean                 @default(false) @map("requires_bank")
  allowDineIn      Boolean                 @default(true) @map("allow_dine_in")
  allowTakeaway    Boolean                 @default(true) @map("allow_takeaway")
  isActive         Boolean                 @default(true) @map("is_active")
  displayOrder     Int                     @default(0) @map("display_order")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  banks            PaymentMethodBank[]
  settlementCounts SettlementMethodCount[]

  @@map("payment_methods")
}

/// 16. REV 2.6: Master bank reusable lintas method.
model Bank {
  id        Int                 @id @default(autoincrement())
  name      String              @unique @db.VarChar(50)
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  methods   PaymentMethodBank[]

  @@map("banks")
}

/// 17. REV 2.6: Junction many-to-many method ↔ bank.
model PaymentMethodBank {
  paymentMethodId Int           @map("payment_method_id")
  bankId          Int           @map("bank_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  bank            Bank          @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@id([paymentMethodId, bankId])
  @@map("payment_method_banks")
}

/// 18. REV 2.6: Settlement child table — dinamis per method, ganti 12 kolom fixed di Settlement.
/// paymentMethodCode denormalize dari payment_methods.code (audit-safe kalau method dihapus/rename).
/// Catatan: relasi `paymentMethod` pakai `onDelete: NoAction` karena paymentMethodCode adalah
/// bagian dari PK composite (tidak boleh null). Original plan mention `SetNull` tapi Prisma
/// tidak izinkan SetNull pada required field. NoAction = MySQL default RESTRICT semantic —
/// method tidak bisa di-hard-delete kalau masih ada settlement_method_counts refers; owner
/// HARUS pakai soft-delete via isActive=false (yang memang flow seharusnya per spec).
/// String code tetap audit-safe karena denormalized as VARCHAR, bukan FK to id.
/// Relation typed nullable (`PaymentMethod?`) adalah Prisma quirk wajib karena relation target
/// `code` (@unique, bukan PK); runtime SELALU resolve row karena NoAction enforce existence.
model SettlementMethodCount {
  settlementId      Int            @map("settlement_id")
  paymentMethodCode String         @map("payment_method_code") @db.VarChar(20)
  counted           Int            @default(0)
  system            Int            @default(0)
  settlement        Settlement     @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  paymentMethod     PaymentMethod? @relation(fields: [paymentMethodCode], references: [code], onDelete: NoAction, onUpdate: NoAction)

  @@id([settlementId, paymentMethodCode])
  @@index([paymentMethodCode])
  @@map("settlement_method_counts")
}
